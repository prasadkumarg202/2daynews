{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/content/**",
              "components/core/**",
              "components/feedback/**",
              "components/navigation/**",
              "components/widgets/**",
              "ui_kits/admin/**",
              "ui_kits/app/**",
              "ui_kits/web/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Anek Latin|Anek Telugu|Anek Tamil|Anek Kannada|Anek Malayalam|Anek Devanagari|Noto Sans|Noto Sans Telugu|Noto Sans Tamil|Noto Sans Kannada|Noto Sans Malayalam|Noto Sans Devanagari|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: Anek Latin, Anek Telugu, Anek Tamil, Anek Kannada, Anek Malayalam, Anek Devanagari, Noto Sans, Noto Sans Telugu, Noto Sans Tamil, Noto Sans Kannada, Noto Sans Malayalam, Noto Sans Devanagari, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|live|children|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, live, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:breaking|live|exclusive|gold|count|success)$/]",
        "message": "<Badge> tone must be one of 'breaking' | 'live' | 'exclusive' | 'gold' | 'count' | 'success'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BreakingTicker'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|items|style|key|ref|className|style|children)$/]",
        "message": "<BreakingTicker> doesn't accept that prop. Declared props: label, items, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|iconRight|block|disabled|children|style|onClick|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, iconRight, block, disabled, children, style, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|soft|inverse)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'soft' | 'inverse'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:category|label|active|solid|size|style|onClick|key|ref|className|style|children)$/]",
        "message": "<CategoryChip> doesn't accept that prop. Declared props: category, label, active, solid, size, style, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryChip'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<CategoryChip> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|label|value|unit|sub|delta|style|key|ref|className|style|children)$/]",
        "message": "<DataTile> doesn't accept that prop. Declared props: kind, label, value, unit, sub, delta, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataTile'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:gold|market|weather|cricket)$/]",
        "message": "<DataTile> kind must be one of 'gold' | 'market' | 'weather' | 'cricket'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LanguagePill'] > JSXAttribute > JSXIdentifier[name!=/^(?:code|native|glyph|active|style|onClick|key|ref|className|style|children)$/]",
        "message": "<LanguagePill> doesn't accept that prop. Declared props: code, native, glyph, active, style, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='LanguagePill'] > JSXAttribute[name.name='code'] > Literal[value!=/^(?:te|ta|kn|ml|hi|en)$/]",
        "message": "<LanguagePill> code must be one of 'te' | 'ta' | 'kn' | 'ml' | 'hi' | 'en'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NewsCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:headline|summary|category|source|time|location|image|layout|breaking|verified|aiRewritten|onClick|style|key|ref|className|style|children)$/]",
        "message": "<NewsCard> doesn't accept that prop. Declared props: headline, summary, category, source, time, location, image, layout, breaking, verified, aiRewritten, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='NewsCard'] > JSXAttribute[name.name='layout'] > Literal[value!=/^(?:row|hero|compact)$/]",
        "message": "<NewsCard> layout must be one of 'row' | 'hero' | 'compact'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionTabs'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|value|onChange|style|key|ref|className|style|children)$/]",
        "message": "<SectionTabs> doesn't accept that prop. Declared props: items, value, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SourceStamp'] > JSXAttribute > JSXIdentifier[name!=/^(?:source|time|location|verified|aiRewritten|style|key|ref|className|style|children)$/]",
        "message": "<SourceStamp> doesn't accept that prop. Declared props: source, time, location, verified, aiRewritten, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
